{
  "log": {
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log",
    "loglevel": "warning",
    "dnsLog": false
  },
  "api": {
    "tag": "api",
    "services": ["HandlerService", "LoggerService", "StatsService"]
  },
  "stats": {},
  "policy": {
    "levels": { "0": { "statsUserUplink": true, "statsUserDownlink": true } },
    "system": { "statsInboundUplink": true, "statsInboundDownlink": true }
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["api"],
        "outboundTag": "api"
      },
      {
        "type": "field",
        "outboundTag": "blocked",
        "protocol": ["bittorrent"]
      }
    ]
  },
  "dns": {
    "servers": ["1.1.1.1", "1.0.0.1", "8.8.8.8", "8.8.4.4"],
    "tag": "dns-in"
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 62789,
      "protocol": "dokodemo-door",
      "settings": { "address": "127.0.0.1" },
      "tag": "api"
    },

    // ── TROJAN ─────────────────────────────────────────────────
    {
      "listen": "127.0.0.1",
      "port": 1001,
      "protocol": "trojan",
      "tag": "trojan-ws",
      "settings": {
        "clients": [
          { "password": "xxxxxx" }
          #trojan
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": { "path": "/trws", "host": "" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http","tls","quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 1002,
      "protocol": "trojan",
      "tag": "trojan-httpupgrade",
      "settings": {
        "clients": [
          { "password": "xxxxxx" }
          #trojan
        ]
      },
      "streamSettings": {
        "network": "httpupgrade",
        "security": "none",
        "httpupgradeSettings": { "path": "/htrojan", "host": "" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http","tls","quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 1003,
      "protocol": "trojan",
      "tag": "trojan-grpc",
      "settings": {
        "clients": [
          { "password": "xxxxxx" }
          #trojangrpc
        ]
      },
      "streamSettings": {
        "network": "grpc",
        "security": "none",
        "grpcSettings": { "serviceName": "trojan-grpc", "multiMode": false }
      },
      "sniffing": { "enabled": true, "destOverride": ["http","tls","quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 1004,
      "protocol": "trojan",
      "tag": "trojan-xhttp",
      "settings": {
        "clients": [
          { "password": "xxxxxx" }
          #trojan
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": { "path": "/xtrojan", "host": "" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http","tls","quic"] }
    },

    // ── VMESS ──────────────────────────────────────────────────
    {
      "listen": "127.0.0.1",
      "port": 2001,
      "protocol": "vmess",
      "tag": "vmess-ws",
      "settings": {
        "clients": [
          { "id": "xxxxxx", "alterId": 0 }
          #vmess
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": { "path": "/vmess", "host": "" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http","tls","quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 2002,
      "protocol": "vmess",
      "tag": "vmess-httpupgrade",
      "settings": {
        "clients": [
          { "id": "xxxxxx", "alterId": 0 }
          #vmess
        ]
      },
      "streamSettings": {
        "network": "httpupgrade",
        "security": "none",
        "httpupgradeSettings": { "path": "/hvmess", "host": "" }
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 2003,
      "protocol": "vmess",
      "tag": "vmess-grpc",
      "settings": {
        "clients": [
          { "id": "xxxxxx", "alterId": 0 }
          #vmessgrpc
        ]
      },
      "streamSettings": {
        "network": "grpc",
        "security": "none",
        "grpcSettings": { "serviceName": "vmess-grpc", "multiMode": false }
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 2004,
      "protocol": "vmess",
      "tag": "vmess-xhttp",
      "settings": {
        "clients": [
          { "id": "xxxxxx", "alterId": 0 }
          #vmess
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": { "path": "/xvmess", "host": "" }
      }
    },

    // ── VLESS ──────────────────────────────────────────────────
    {
      "listen": "127.0.0.1",
      "port": 3001,
      "protocol": "vless",
      "tag": "vless-ws",
      "settings": {
        "clients": [
          { "id": "xxxxxx" }
          #vless
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": { "path": "/vless", "host": "" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http","tls","quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 3002,
      "protocol": "vless",
      "tag": "vless-httpupgrade",
      "settings": {
        "clients": [
          { "id": "xxxxxx" }
          #vless
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "httpupgrade",
        "security": "none",
        "httpupgradeSettings": { "path": "/hvless", "host": "" }
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 3003,
      "protocol": "vless",
      "tag": "vless-grpc",
      "settings": {
        "clients": [
          { "id": "xxxxxx" }
          #vlessgrpc
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "grpc",
        "security": "none",
        "grpcSettings": { "serviceName": "vless-grpc", "multiMode": false }
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 3004,
      "protocol": "vless",
      "tag": "vless-xhttp",
      "settings": {
        "clients": [
          { "id": "xxxxxx" }
          #vless
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": { "path": "/xvless", "host": "" }
      }
    },

    // ── SOCKS ──────────────────────────────────────────────────
    {
      "listen": "127.0.0.1",
      "port": 4001,
      "protocol": "socks",
      "tag": "socks-ws",
      "settings": {
        "auth": "password",
        "accounts": [
          { "user": "xxxxxx", "pass": "xxxxxx" }
          #socks
        ],
        "udp": true
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": { "path": "/ssws", "host": "" }
      }
    }
  ],
  "outbounds": [
    { "tag": "direct", "protocol": "freedom", "settings": {} },
    { "tag": "blocked", "protocol": "blackhole", "settings": {} },
    {
      "tag": "api",
      "protocol": "freedom",
      "settings": {}
    }
  ]
}
